{
  "elements": {
    "Domain": {
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["level", "owner"],
      "optional_properties": ["description", "cost_center"]
    },
    "Subdomain": {
      "extend": "Domain",
      "is_owned_by_one_of": ["Domain"],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["capability"],
      "optional_properties": ["maturity"]
    },
    "Application": {
      "is_owned_by_one_of": ["Domain", "Subdomain"],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["version", "status", "tier"],
      "optional_properties": ["description", "vendor", "license_type"]
    },
    "WebApplication": {
      "extend": "Application",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["url", "framework"],
      "optional_properties": ["cdn_enabled", "ssl_cert_expiry"]
    },
    "MobileApplication": {
      "extend": "Application",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["platform", "min_os_version"],
      "optional_properties": ["app_store_url", "push_enabled"]
    },
    "BatchJob": {
      "extend": "Application",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["schedule_cron", "max_runtime_minutes"],
      "optional_properties": ["retry_policy", "concurrency_limit"]
    },
    "Service": {
      "is_owned_by_one_of": ["Application", "WebApplication", "MobileApplication"],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["protocol", "port", "status"],
      "optional_properties": ["healthcheck_path", "timeout_ms"]
    },
    "APIEndpoint": {
      "extend": "Service",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["base_path", "auth_method"],
      "optional_properties": ["rate_limit", "api_version", "openapi_spec_url"]
    },
    "MessageQueue": {
      "extend": "Service",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["topic", "consumer_group"],
      "optional_properties": ["retention_hours", "max_message_size_kb", "dlq_enabled"]
    },
    "Environment": {
      "is_owned_by_one_of": ["Domain"],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["stage", "region"],
      "optional_properties": ["vpc_id", "cost_tag"]
    },
    "Server": {
      "is_owned_by_one_of": ["Environment"],
      "is_typed_by_one_of": [],
      "id_properties": ["hostname"],
      "properties": ["os", "ip_address", "status"],
      "optional_properties": ["cpu_count", "memory_gb", "disk_gb"]
    },
    "VirtualMachine": {
      "extend": "Server",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["image_id", "instance_type"],
      "optional_properties": ["auto_scaling_group", "spot_eligible"]
    },
    "Container": {
      "extend": "Server",
      "is_owned_by_one_of": [],
      "is_typed_by_one_of": [],
      "id_properties": [],
      "properties": ["image_repo", "image_tag"],
      "optional_properties": ["cpu_request", "memory_request", "namespace"]
    },
    "Database": {
      "is_owned_by_one_of": ["Environment"],
      "is_typed_by_one_of": ["Server"],
      "id_properties": ["name"],
      "properties": ["engine", "version", "port"],
      "optional_properties": ["storage_gb", "replicas", "backup_schedule", "encrypted"]
    },
    "Schema": {
      "is_owned_by_one_of": ["Database"],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["charset"],
      "optional_properties": ["table_count", "size_mb"]
    },
    "Network": {
      "is_owned_by_one_of": ["Environment"],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["cidr", "zone"],
      "optional_properties": ["gateway", "dns_servers"]
    },
    "LoadBalancer": {
      "is_owned_by_one_of": ["Network"],
      "is_typed_by_one_of": ["Server"],
      "id_properties": ["name"],
      "properties": ["algorithm", "listener_port"],
      "optional_properties": ["ssl_policy", "idle_timeout_sec"]
    },
    "Team": {
      "is_owned_by_one_of": ["Domain", "Subdomain"],
      "is_typed_by_one_of": [],
      "id_properties": ["name"],
      "properties": ["lead", "email"],
      "optional_properties": ["slack_channel", "on_call_rotation"]
    },
    "Pipeline": {
      "is_owned_by_one_of": ["Team"],
      "is_typed_by_one_of": ["Environment"],
      "id_properties": ["name"],
      "properties": ["trigger", "target_env"],
      "optional_properties": ["approval_required", "parallel_stages"]
    }
  },
  "relationships": {
    "Allocate": {
      "properties": ["priority", "allocated_at"],
      "mappings": [
        { "source": "Application", "destination": "Server" },
        { "source": "Application", "destination": "Environment" },
        { "source": "Service", "destination": "Server" },
        { "source": "Database", "destination": "Server" }
      ]
    },
    "DependsOn": {
      "properties": ["dependency_type", "criticality"],
      "mappings": [
        { "source": "Application", "destination": "Application" },
        { "source": "Service", "destination": "Service" },
        { "source": "Application", "destination": "Database" },
        { "source": "Service", "destination": "Database" },
        { "source": "Service", "destination": "MessageQueue" }
      ]
    },
    "Contains": {
      "properties": [],
      "mappings": [
        { "source": "Domain", "destination": "Application" },
        { "source": "Domain", "destination": "Environment" },
        { "source": "Environment", "destination": "Server" },
        { "source": "Environment", "destination": "Database" },
        { "source": "Environment", "destination": "Network" }
      ]
    },
    "Exposes": {
      "properties": ["visibility"],
      "mappings": [
        { "source": "Application", "destination": "APIEndpoint" },
        { "source": "Application", "destination": "Service" }
      ]
    },
    "Consumes": {
      "properties": ["sla_ms", "circuit_breaker"],
      "mappings": [
        { "source": "Application", "destination": "APIEndpoint" },
        { "source": "Service", "destination": "APIEndpoint" },
        { "source": "WebApplication", "destination": "APIEndpoint" },
        { "source": "MobileApplication", "destination": "APIEndpoint" }
      ]
    },
    "RoutesTo": {
      "properties": ["weight"],
      "mappings": [
        { "source": "LoadBalancer", "destination": "Server" },
        { "source": "LoadBalancer", "destination": "Service" }
      ]
    },
    "Publishes": {
      "properties": ["format"],
      "mappings": [
        { "source": "Service", "destination": "MessageQueue" },
        { "source": "Application", "destination": "MessageQueue" }
      ]
    },
    "Subscribes": {
      "properties": ["format", "filter_expression"],
      "mappings": [
        { "source": "Service", "destination": "MessageQueue" },
        { "source": "BatchJob", "destination": "MessageQueue" }
      ]
    },
    "ReadsFrom": {
      "properties": ["access_mode"],
      "mappings": [
        { "source": "Application", "destination": "Schema" },
        { "source": "Service", "destination": "Schema" }
      ]
    },
    "WritesTo": {
      "properties": ["access_mode"],
      "mappings": [
        { "source": "Application", "destination": "Schema" },
        { "source": "Service", "destination": "Schema" },
        { "source": "BatchJob", "destination": "Schema" }
      ]
    },
    "Deploys": {
      "properties": ["strategy"],
      "mappings": [
        { "source": "Pipeline", "destination": "Application" },
        { "source": "Pipeline", "destination": "Service" },
        { "source": "Pipeline", "destination": "Database" }
      ]
    },
    "Owns": {
      "properties": ["responsibility"],
      "mappings": [
        { "source": "Team", "destination": "Application" },
        { "source": "Team", "destination": "Service" },
        { "source": "Team", "destination": "Pipeline" },
        { "source": "Team", "destination": "Database" }
      ]
    },
    "ConnectsVia": {
      "properties": ["encryption"],
      "mappings": [
        { "source": "Server", "destination": "Network" },
        { "source": "Database", "destination": "Network" }
      ]
    }
  }
}
